# Copy relevant lines into your Dify docker/.env or Dify Console → Settings → Variables.
# Dify runs in Docker; Twelvewin API runs on the host (uvicorn :8090).

# Base URL reachable FROM INSIDE Dify containers (not 127.0.0.1).
TWELVEWIN_API=http://host.docker.internal:8090

# Must match TW_RESEARCH_API_KEY in Twelvewin root .env (when API key auth is enabled).
TW_RESEARCH_API_KEY=change-me-to-a-long-random-string

# Linux: if host.docker.internal fails, add to dify docker-compose.yaml:
#   extra_hosts:
#     - "host.docker.internal:host-gateway"
# Or use host LAN IP, e.g. TWELVEWIN_API=http://192.168.1.10:8090
