# Copy to .env and edit for your machine / deployment (do not commit .env).
# INI files (config.ini, production.cfg) are not used.

# --- Environment (pick one; drives Flask behavior when APP_SETTINGS is unset) ---
# local | development | production | test
APP_ENV=local

# Optional: override Flask config class explicitly
# APP_SETTINGS=app.config.LocalConfig

# --- Database & cache ---
DATABASE_URL=postgresql+psycopg://USER:PASSWORD@HOST/DBNAME?sslmode=require
# Local SQLite example:
# DATABASE_URL=sqlite:////absolute/path/to/local_data/twelvewin.sqlite
REDIS_URL=redis://:@127.0.0.1:6379/0

# --- Web server ---
DEBUG=true
PORT=8088

# --- Data paths (optional; default under local_data/) ---
# DAY_FILE_PATH=/absolute/path/to/day_data/
# RESULT_PATH=/absolute/path/to/results/
# INDEX_FILE_PATH=/absolute/path/to/index_data/

# --- Analysis publish / read ---
READ_ANALYSIS_FROM_DB=true
CSV_DEV_FALLBACK=false

# --- Dify agent / Research API tool auth (optional) ---
# When set, Dify HTTP tools should send header: X-Twelvewin-Api-Key
# TW_RESEARCH_API_KEY=change-me-to-a-long-random-string
# TW_AGENT_ENABLED=true

# --- Secrets (required in production) ---
SECRET_KEY=change-me
SECURITY_PASSWORD_SALT=change-me

# --- Mail (production / password reset) ---
# APP_MAIL_SERVER=smtp.example.com
# APP_MAIL_PORT=465
# APP_MAIL_USE_TLS=false
# APP_MAIL_USE_SSL=true
# APP_MAIL_USERNAME=
# APP_MAIL_PASSWORD=
# APP_MAIL_DEFAULT_SENDER=no-reply@example.com

# --- Stripe (production only) ---
# STRIPE_SECRET_KEY=
# STRIPE_PUBLISHABLE_KEY=

# --- Offline / market data ---
# TUSHARE_TOKEN=
# TW_DATA_PROVIDER=auto
# TW_MARKET_DATA_PROVIDER=auto
# TW_WRITE_RESULT_CSV=false
# TW_WRITE_DAY_CSV=false
# Limit download_history batch size (0 = all instruments; useful for smoke tests)
# TW_HISTORY_MAX_CODES=0
# TW_SYNC_CSV_TO_DB=false
# TW_RUN_ANNUAL_REPORT=false
# TW_ANNUAL_REPORT_YEAR=2025
# TW_RUN_FINANCE_PROFILE=false
# TW_FINANCE_PROFILE_YEARS=5
# TW_FINANCE_PROFILE_MAX_CODES=0
# TW_FINANCE_PROFILE_CODES=000755,600519
# TW_FINANCE_PROFILE_SLEEP_SEC=0.35

# Optional: use a non-default dotenv path (CI)
# DOTENV_PATH=/path/to/.env
