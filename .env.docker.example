# Docker Compose environment for Twelvewin OSS stack.
# Copy to repository root as .env before running docker compose.
#
#   cp .env.docker.example .env
#   docker compose up -d --build

APP_ENV=production

# Overridden by docker-compose.yml for in-network services.
# DATABASE_URL=postgresql+psycopg://twelvewin:twelvewin@postgres:5432/twelvewin
# REDIS_URL=redis://redis:6379/0

SECRET_KEY=change-me-in-production
SECURITY_PASSWORD_SALT=change-me-in-production

READ_ANALYSIS_FROM_DB=true
CSV_DEV_FALLBACK=false
TWELVEWIN_DISABLE_ANALYZER=1

# --- Market data (required for compute jobs profile) ---
# TUSHARE_TOKEN=your-token
# TW_MARKET_DATA_PROVIDER=akshare
# TW_TUSHARE_FINANCIAL_MAX_CODES=0

# Optional smoke-test limits
# TW_HISTORY_MAX_CODES=50

# Optional CSV mirrors under local_data/
# TW_WRITE_RESULT_CSV=false
# TW_WRITE_DAY_CSV=false

# API CORS (also set in docker-compose for the api service)
# API_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
